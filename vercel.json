{
  "version": 2,
  "regions": ["hkg1"],
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/fetch?source=all",
      "schedule": "0 2 * * *"
    }
  ]
}